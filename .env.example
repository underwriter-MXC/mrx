# Public site analytics and account client
PUBLIC_GTM_ID=
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.6-luna
OPENAI_COMPLEX_MODEL=gpt-5.6-terra
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Supabase server access
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# GoHighLevel private integration. The token needs contacts.write,
# conversations/message.write, calendars.readonly, calendars/events.write,
# and webhook scopes for the configured sub-account.
GHL_PRIVATE_INTEGRATION_TOKEN=
# Optional: the server can resolve this from the configured calendar.
GHL_LOCATION_ID=
# Existing MRX GoHighLevel booking calendar (the server verifies it belongs to the configured location).
GHL_CALENDAR_ID=lg3KcWfsKrR2pCWS6AeL
GHL_WEBHOOK_PUBLIC_KEY=

# Private document processing
MALWARE_SCAN_URL=
MALWARE_SCAN_TOKEN=
DOCUMENT_OCR_URL=
