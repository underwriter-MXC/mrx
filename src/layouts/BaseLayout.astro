---
/**
 * BaseLayout. The global shell. Used by every page (MarketingLayout
 * and PostLayout extend it).
 *
 * Per `Astro Architecture Plan.md` §3. This is the global layout that
 * emits <html>, <head>, header, and footer (with §7 disclaimer).
 * MarketingLayout and PostLayout pass children through.
 */
import '../styles/index.css';
import Header from '../components/organisms/Header.astro';
import Footer from '../components/organisms/Footer.astro';
import Seo from '../components/seo/Seo.astro';
import type { Crumb } from '../structured-data/breadcrumb';
import { initDataLayer } from '../lib/analytics';
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  noindex?: boolean;
  robots?: string;
  jsonLd?: object[];
  breadcrumbs?: Crumb[];
  pageType: 'home' | 'marketing' | 'blog' | 'post' | 'utility';
  pageCategory?: string;
  hideHeader?: boolean;
}

const {
  title,
  description,
  path,
  ogImage,
  noindex = false,
  robots,
  jsonLd = [],
  breadcrumbs,
  pageType,
  pageCategory,
  hideHeader = false,
} = Astro.props;
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a2540" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} Blog`} href="/blog/rss.xml" />
    <Seo
      title={title}
      description={description}
      path={path}
      ogImage={ogImage}
      noindex={noindex}
      robots={robots}
      jsonLd={jsonLd}
      breadcrumbs={breadcrumbs}
    />
    <script
      is:inline
      define:vars={{ pageType, pageCategory }}
    >
      // GTM/GA4 dataLayer init (per SEO plan §6.2). The GTM container
      // itself is loaded only if PUBLIC_GTM_ID is set; the dataLayer shim
      // stays on so conversion events are testable even before GTM fires.
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        'gtm.start': Date.now(),
        event: 'gtm.js',
        mrx_page_type: pageType,
        mrx_page_category: pageCategory || null,
      });

      function __mrxEventId(name) {
        var rand = Math.random().toString(36).slice(2);
        var ts = Date.now().toString(36);
        return 'mrx_' + name + '_' + ts + '_' + rand;
      }

      function __mrxParams(extra) {
        var url = new URL(window.location.href);
        return Object.assign({
          event_id: __mrxEventId((extra && extra.event) || 'event'),
          page_location: window.location.href,
          page_path: window.location.pathname,
          page_title: document.title,
          page_category: pageCategory || null,
          mrx_page_type: pageType,
          mrx_page_category: pageCategory || null,
          utm_source: url.searchParams.get('utm_source') || undefined,
          utm_medium: url.searchParams.get('utm_medium') || undefined,
          utm_campaign: url.searchParams.get('utm_campaign') || undefined,
          utm_term: url.searchParams.get('utm_term') || undefined,
          utm_content: url.searchParams.get('utm_content') || undefined,
          gclid_present: url.searchParams.has('gclid'),
          fbclid_present: url.searchParams.has('fbclid'),
        }, extra || {});
      }

      function __mrxPush(payload) { window.dataLayer.push(__mrxParams(payload)); }
      window.__mrxPush = __mrxPush;

      document.addEventListener('DOMContentLoaded', function () {
        // Recommended MRX page view event used by GTM/GA4/Meta mappings.
        __mrxPush({ event: 'mrx_page_view' });

        // Treat the native /book page as the current booking/calendar view
        // surface until a dedicated embedded calendar is added.
        if (window.location.pathname.replace(/\/$/, '') === '/book') {
          __mrxPush({
            event: 'calendar_view',
            calendar_id: 'native-book-form',
            calendar_source: 'book_page',
          });
        }

        document.querySelectorAll('a[data-cta-name]').forEach(function (link) {
          link.addEventListener('click', function () {
            var name = link.getAttribute('data-cta-name') || 'unknown';
            var href = link.getAttribute('href') || '';
            __mrxPush({
              event: 'book_cta_click',
              cta_name: name,
              link_text: (link.textContent || '').trim(),
              link_url: href,
            });
            // Backward-compatible event name used by older MRX dashboards.
            __mrxPush({ event: 'cta_click', mrx_cta_name: name, mrx_href: href });
          });
        });

        document.querySelectorAll('a[href^="tel:"]').forEach(function (link) {
          link.addEventListener('click', function () {
            __mrxPush({
              event: 'phone_click',
              link_text: (link.textContent || '').trim(),
              link_url: link.getAttribute('href') || '',
            });
          });
        });

        document.querySelectorAll('a[href^="mailto:"], a[href*="/cdn-cgi/l/email-protection"]').forEach(function (link) {
          link.addEventListener('click', function () {
            __mrxPush({
              event: 'mailto_click',
              link_text: (link.textContent || '').trim(),
              link_url: link.getAttribute('href') || '',
            });
          });
        });
      });
    </script>
    {
      import.meta.env.PUBLIC_GTM_ID && (
        <script
          is:inline
          async
          src={`https://www.googletagmanager.com/gtm.js?id=${import.meta.env.PUBLIC_GTM_ID}`}
        />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <div class="page">
      {!hideHeader && <Header currentPath={path} />}
      <main class="page__main" id="main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
