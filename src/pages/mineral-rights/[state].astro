---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { stateGuides, type StateGuide } from '../../data/states';
export const prerender = true;
export function getStaticPaths(){return stateGuides.map((state)=>({params:{state:state.slug},props:{state}}));}
const { state } = Astro.props as { state: StateGuide };
---
<MarketingLayout title={`${state.name} Mineral Rights Owner Guide · MRX`} description={`A reviewed starting point for ${state.name} mineral owners comparing offers, inherited interests, royalty information, public records, and production questions.`} path={`/mineral-rights/${state.slug}/`} pageType="marketing" pageCategory="seller-intent" breadcrumbs={[{name:'Home',path:'/'},{name:`${state.name} Mineral Rights`,path:`/mineral-rights/${state.slug}/`}]}>
  <section class="mrx-page-hero"><div class="container mrx-page-hero__grid"><div><p class="mrx-eyebrow">{state.name} owner starting point</p><h1>{state.name} mineral rights questions start with state and county facts.</h1><p>{state.overview}</p><button class="mrx-primary" type="button" data-state-prompt={`I have mineral rights in ${state.name}. Help me figure out what information matters first.`}>Ask Tommy about {state.name}</button></div><aside class="mrx-answer-card"><h2>Authoritative public starting point</h2><p>The state regulator publishes well, permitting, production, or operator information relevant to owner research.</p><p><a href={state.regulator.url} target="_blank" rel="noopener">Visit {state.regulator.name} ↗</a></p><small>County records, estate rules, taxes, and contract questions may involve additional agencies or qualified state-specific professionals.</small></aside></div></section>
  <section class="mrx-section"><div class="container mrx-prose-grid"><div><h2>Common {state.name} owner questions</h2><ul>{state.commonQuestions.map((question)=><li>{question}</li>)}</ul><h2>Information worth gathering</h2><p>Start with the county and legal description, how the interest was acquired, net ownership if known, lease or division-order documents, recent royalty statements, operator details, and the full written offer.</p><h2>Why the answer still needs context</h2><p>Public well activity and production data can add context, but they do not by themselves settle ownership, title, future development, contract meaning, or a transaction amount. MRX separates public facts from assumptions and unanswered questions.</p></div><aside class="mrx-side-cta"><h3>Ask in your own words</h3><p>Tell Tommy the state, county, and whether you have an offer, royalty statement, inheritance document, or operator letter.</p><button type="button" data-state-prompt={`I have mineral rights in ${state.name}. Help me figure out what information matters first.`}>Ask Tommy</button></aside></div></section>
</MarketingLayout>
<script>document.querySelectorAll<HTMLElement>('[data-state-prompt]').forEach((button)=>button.addEventListener('click',()=>window.dispatchEvent(new CustomEvent('mrx:open-chat',{detail:{prompt:button.dataset.statePrompt}}))));</script>
