---
import { getEntry } from 'astro:content';
import MarketingLayout from '../layouts/MarketingLayout.astro';

const entry = await getEntry('pages', 'privacy-policy');
if (!entry) throw new Error('pages/privacy-policy.mdx is missing.');
const { Content } = await entry.render();
export const prerender = true;
---

<MarketingLayout
  title={entry.data.title}
  description={entry.data.description}
  path="/privacy-policy"
  pageType="utility"
  pageCategory="legal"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Privacy Policy', path: '/privacy-policy' }]}
  disclaimerTop={entry.data.disclaimer_top}
>
  <Content />
</MarketingLayout>
