---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import IntentPage from '../components/organisms/IntentPage.astro';
export const prerender = true;
---
<MarketingLayout title="Review a Mineral Rights Offer Before Signing · MRX" description="Received a mineral-rights offer? Check the property description, net ownership, adjustment rights, closing terms, and assumptions before you respond." path="/offer-review/" pageType="marketing" pageCategory="seller-intent" breadcrumbs={[{name:'Home',path:'/'},{name:'Review My Offer',path:'/offer-review/'}]}>
  <IntentPage eyebrow="Look beyond the headline" title="Received a mineral rights offer? Check what the number really covers." lede="An offer may look simple while leaving important details in the property exhibit, title-adjustment language, closing conditions, and buyer rights. Organize those pieces before you compare or sign." answerTitle="Check these first" answerPoints={['The exact acres, depths, counties, and interests included','Whether the amount is gross, net, per acre, or total','What the buyer can change after title or diligence review','Closing date, payment conditions, assignments, and termination rights']} prompt="I received a mineral rights offer. Help me understand what to check before I respond." sections={[{title:'Start with the property description',paragraphs:['Confirm that the offer covers only the interests you intend to discuss. Look for county, survey, section, township, range, unit, well, depth, and net-acre language. Broad wording deserves careful review.']},{title:'Find every adjustment right',paragraphs:['Some offers allow the buyer to revise the amount after reviewing ownership, title, production, or other records. Identify who decides, how changes are calculated, whether you can reject a revision, and what happens to signed documents.'],bullets:['Ask whether the headline amount assumes a specific net acreage.','Identify deposits, option periods, exclusivity, or extensions.','Keep copies of every version and written communication.']},{title:'Know when to involve a professional',paragraphs:['Title, probate, conveyance, tax, and contract questions can be state-specific. Rebecca can explain common terms and help prepare a question list, but an attorney or tax professional should address individualized conclusions.']}]}/>
</MarketingLayout>
