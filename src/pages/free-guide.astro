---
import { getEntry } from 'astro:content';
import MarketingLayout from '../layouts/MarketingLayout.astro';

const entry = await getEntry('pages', 'free-guide');
if (!entry) throw new Error('pages/free-guide.mdx is missing.');
const { Content } = await entry.render();
export const prerender = true;
---

<MarketingLayout
  title={entry.data.title}
  description={entry.data.description}
  path="/free-guide"
  pageType="marketing"
  pageCategory="free-guide"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Free Guide', path: '/free-guide' }]}
  faq={entry.data.faq}
>
  <Content />
</MarketingLayout>
