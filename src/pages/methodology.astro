---
import { getEntry } from 'astro:content';
import MarketingLayout from '../layouts/MarketingLayout.astro';

const entry = await getEntry('pages', 'methodology');
if (!entry) throw new Error('pages/methodology.mdx is missing.');
const { Content } = await entry.render();
export const prerender = true;
---

<MarketingLayout
  title={entry.data.title}
  description={entry.data.description}
  path="/methodology"
  pageType="marketing"
  pageCategory="methodology"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Methodology', path: '/methodology' }]}
  faq={entry.data.faq}
  disclaimerTop={entry.data.disclaimer_top}
>
  <Content />
</MarketingLayout>
