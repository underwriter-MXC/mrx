---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import IntentPage from '../components/organisms/IntentPage.astro';
export const prerender = true;
---
<MarketingLayout title="Inherited Mineral Rights: First Steps · MRX" description="Inherited mineral rights? Organize probate records, deeds, division orders, royalty statements, county details, and operator information before deciding." path="/inherited-mineral-rights/" pageType="marketing" pageCategory="seller-intent" breadcrumbs={[{name:'Home',path:'/'},{name:'Inherited Rights',path:'/inherited-mineral-rights/'}]}>
  <IntentPage eyebrow="Build the paper trail" title="Inherited mineral rights? Start with the records, not an offer." lede="You do not need every document on day one. Begin with the person who owned the interest, how it passed, where it is located, and any operator or royalty information already in the family files." answerTitle="Useful starting documents" answerPoints={['Will, trust, probate order, affidavit, or estate records','Recorded deeds, assignments, leases, and division orders','Recent royalty statements, tax forms, and operator letters','State, county, legal description, well, and operator details']} prompt="I inherited mineral rights and need help figuring out the first steps and documents." sections={[{title:'Connect the prior owner to the current heirs',paragraphs:['The required path depends on the state, county, estate process, and how the interest was titled. Cooper can help organize the documents and public-record questions, but title conclusions belong with a qualified professional.']},{title:'Contact the operator carefully',paragraphs:['If royalties are being held or ownership has changed, an operator may request transfer documents and tax information. Ask for the operator’s written owner-relations requirements and keep a record of what was submitted.'],bullets:['Do not send original estate documents when a certified or ordinary copy is sufficient.','Confirm contact information through the operator’s official website or public filings.','Track suspense balances, ownership decimals, and effective dates.']},{title:'Do not let an unsolicited offer define the research',paragraphs:['An offer can be a reason to investigate, but it does not establish ownership or value by itself. First determine what the estate may own and which facts can be verified.']}]}/>
</MarketingLayout>
