---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeExperience from '../components/organisms/HomeExperience.astro';

const title = 'Mineral Rights Answers Before You Sign · MRX';
const description = 'Got a mineral-rights offer? Ask Tommy for free, no-pressure educational help with value factors, inherited rights, royalties, and what to check next.';
export const prerender = true;
---

<BaseLayout title={title} description={description} path="/" pageType="home" pageCategory="homepage">
  <HomeExperience />
</BaseLayout>
