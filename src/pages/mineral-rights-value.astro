---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import IntentPage from '../components/organisms/IntentPage.astro';
export const prerender = true;
---
<MarketingLayout title="What Affects Mineral Rights Value? · MRX" description="Understand the location, ownership, production, geology, timing, market assumptions, and agreement terms that can affect a mineral-rights offer." path="/mineral-rights-value/" pageType="marketing" pageCategory="seller-intent" breadcrumbs={[{name:'Home',path:'/'},{name:'Value My Minerals',path:'/mineral-rights-value/'}]}>
  <IntentPage eyebrow="Understand the inputs" title="What might affect what your mineral rights are worth?" lede="A useful answer is built from facts and assumptions—not a teaser number. Start with the interest, the location, current production, nearby development, timing, and the exact transaction terms." answerTitle="A value review usually needs" answerPoints={['State, county, legal description, and net ownership','Current wells, operator, production, and royalty information','Nearby permits, development timing, and geological context','The complete offer terms—not only the headline amount']} prompt="Help me understand what may affect the value of my mineral rights." sections={[{title:'There is no single public price tag',paragraphs:['Mineral interests are not interchangeable parcels. Two interests in the same county can differ because of net acreage, royalty burden, depth, lease terms, producing wells, spacing, development timing, and title history.','Any comparison should state what information was used, which assumptions were made, and which facts still need verification.']},{title:'Producing and non-producing interests look different',paragraphs:['Producing interests can be studied using royalty statements and public production history. Non-producing interests rely more heavily on location, lease position, permits, nearby activity, operator plans, and uncertainty.'],bullets:['Gather several recent royalty statements rather than relying on one check.','Confirm the ownership decimal and the wells included.','Separate current cash flow from possible future development.']},{title:'Offer terms change the comparison',paragraphs:['A headline number can change after title review or may apply to more acres, depths, or interests than expected. Review what can be adjusted, what must be delivered, and what happens if the buyer finds a title issue.']}]}/>
</MarketingLayout>
