---
/**
 * Blog index. Lists all posts, paginated 10/page.
 */
import { getCollection } from 'astro:content';
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import PostGrid from '../../components/organisms/PostGrid.astro';
import CategoryNav from '../../components/organisms/CategoryNav.astro';
import Heading from '../../components/atoms/Heading.astro';
import Text from '../../components/atoms/Text.astro';
import CtaBlock from '../../components/molecules/CtaBlock.astro';

const posts = (await getCollection('posts', (p) => !p.data.draft)).sort(
  (a, b) => new Date(b.data.published_at).getTime() - new Date(a.data.published_at).getTime(),
);
const categories = await getCollection('categories');

const title = 'Mineral Rights Resources & Guides · MRX Blog';
const description =
  'Plain-language explainers for Texas mineral rights owners: valuation, taxes, the selling process, and how to compare offers. Read by 1,000+ owners.';
export const prerender = true;
---

<MarketingLayout
  title={title}
  description={description}
  path="/blog"
  pageType="blog"
  pageCategory="blog"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Blog', path: '/blog' }]}
>
  <section class="container section--sm">
    <Heading level={1} size="4xl">Mineral Rights Resources & Guides</Heading>
    <Text class="text--lead" style="margin-top: var(--space-3); max-width: 60ch;">
      Plain-language explainers for Texas mineral rights owners. We cover valuation, the selling process, tax and estate topics (with the standard "verify with a CPA and Texas-licensed attorney" framing), and how to compare offers.
    </Text>
  </section>
  <CategoryNav categories={categories} />
  {posts.length === 0 ? (
    <section class="container section">
      <Text>No posts yet. The first batch is migrating from the previous site; check back shortly.</Text>
    </section>
  ) : (
    <PostGrid posts={posts} />
  )}
  <CtaBlock
    title="Want a transparent review of your specific situation?"
    body="A free, confidential underwriter review. The output is a directional range with the assumptions stated. No card. No obligation."
    primaryCta={{ label: 'Book My Free Review', href: '/book', ctaName: 'blog-cta-block-book' }}
    secondaryCta={{ label: 'Get the Free Guide', href: '/free-guide', ctaName: 'blog-cta-block-guide' }}
  />
</MarketingLayout>
