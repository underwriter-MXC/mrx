---
/**
 * 500 page. Generic server error. Server route failures render this.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout
  title="Something went wrong · Mineral Rights Xchange"
  description="The page failed to load. Please try again, or visit a different page. Mineral Rights Xchange: free underwriter reviews for Texas mineral rights owners."
  path="/500"
  noindex={true}
  pageType="utility"
  pageCategory="500"
>
  <section class="error-page">
    <div>
      <p class="error-page__code">500</p>
      <h1 style="font-size: var(--fs-3xl); margin-top: var(--space-3);">Something went wrong on our end.</h1>
      <p style="margin-top: var(--space-3); color: var(--color-ink-600);">The page failed to load. Please try again, or visit a different page. If the problem persists, the team has been notified.</p>
      <p style="margin-top: var(--space-4);"><a href="/" data-cta-name="500-home">Back to home →</a></p>
    </div>
  </section>
</BaseLayout>
