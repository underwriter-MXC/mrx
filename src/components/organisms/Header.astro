---
/**
 * Header organism. Nav + logo + mobile menu. Used by BaseLayout.
 *
 * Active route highlighting is via aria-current="page" on the
 * matching <a> (handled by per-page consumers passing the
 * currentPath prop).
 */
import { NAV, SITE } from '../../lib/site';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
---

<header class="header" role="banner">
  <div class="container">
    <div class="header__inner">
      <a class="header__brand" href="/" aria-label={`${SITE.name} home`}>
        <img
          src="/assets/brand/mrx-logo-color.png"
          alt=""
          width="400"
          height="100"
          aria-hidden="true"
        />
      </a>
      <nav class="header__nav" aria-label="Primary">
        {
          NAV.primary.map((item) => (
            <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="header__actions">
        <button class="header__ask" type="button" data-open-tommy data-cta-name="header-ask-tommy">
          <img
            src="/assets/mrx-homepage-v4/avatars/tommy-hermes-128.webp"
            alt=""
            width="128"
            height="128"
          />
          <span><strong>Ask Tommy</strong><small>Straight answers, 24/7</small></span>
        </button>
        <button
          class="header__toggle"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-nav"
          data-mobile-toggle
        >
          <span aria-hidden="true"></span><span aria-hidden="true"></span><span aria-hidden="true"
          ></span>
        </button>
      </div>
    </div>
    <nav class="mobile-nav" id="mobile-nav" data-open="false" aria-label="Mobile primary">
      <ul>
        {
          NAV.primary.map((item) => (
            <li>
              <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <button class="mobile-nav__ask" type="button" data-open-tommy
            ><img
              src="/assets/mrx-homepage-v4/avatars/tommy-hermes-128.webp"
              alt=""
              width="128"
              height="128"
            /> Ask Tommy for help</button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  // Tiny client-side toggle. The site ships zero JS by default; this
  // ~10 lines is the entire client JS payload on the marketing surface.
  const btn = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
  const nav = document.getElementById('mobile-nav');
  if (btn && nav) {
    btn.addEventListener('click', () => {
      const open = nav.getAttribute('data-open') === 'true';
      nav.setAttribute('data-open', open ? 'false' : 'true');
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
    });
  }
  document.querySelectorAll<HTMLElement>('[data-open-tommy]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('mrx:open-chat'));
      nav?.setAttribute('data-open', 'false');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
