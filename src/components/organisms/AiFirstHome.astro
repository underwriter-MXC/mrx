---
const quickStarts = [
  { icon: '/assets/mrx-homepage-v4/icons/hmpg-v6-exact/money-bag.png', label: 'What are my minerals worth?', prompt: 'I want to understand what my mineral rights may be worth.' },
  { icon: '/assets/mrx-homepage-v4/icons/hmpg-v6-exact/document-card.png', label: 'I received an offer. Is it fair?', prompt: 'I received an offer for my mineral rights and want help understanding whether it is fair.' },
  { icon: '/assets/mrx-homepage-v4/icons/hmpg-v6-exact/gift-inherited.png', label: 'I inherited mineral rights. What now?', prompt: 'I inherited mineral rights and need help figuring out what documents and details matter first.' },
  { icon: '/assets/mrx-homepage-v4/icons/hmpg-v6-exact/royalty-droplet.png', label: 'I receive royalties. Should I sell?', prompt: 'I receive royalty checks and want help deciding whether I should sell.' },
  { icon: '/assets/mrx-homepage-v4/icons/hmpg-v6-exact/map-pin.png', label: 'What information do you need?', prompt: 'What information does MRX need to review my mineral rights?' },
  { icon: '/assets/mrx-homepage-v4/icons/hmpg-v6-exact/trend-up.png', label: 'Should I sell now or wait?', prompt: 'I want help thinking through whether I should sell now or wait.' },
];

const proofItems = [
  { icon: '/assets/mrx-homepage-v4/icons/hmpg-v6-exact/shield-check.png', title: 'Free', text: 'No cost. No catch.' },
  { icon: '/assets/mrx-homepage-v4/icons/hmpg-v6-exact/lock.png', title: 'Confidential', text: 'Your information stays private.' },
  { icon: '/assets/mrx-homepage-v4/icons/hmpg-v6-exact/circle-check.png', title: 'No Obligation', text: 'You’re never obligated to sell.' },
  { icon: '/assets/mrx-homepage-v4/icons/hmpg-v6-exact/hands-no-pressure.png', title: 'No Pressure', text: 'Answers first, pressure never.' },
];

const pathways = [
  { title: 'Offer review', text: 'Compare the headline number with the assumptions behind it before signing anything.' },
  { title: 'Royalty check questions', text: 'Understand what recent checks, production history, and decline context may imply.' },
  { title: 'Inherited minerals', text: 'Walk through documents, county/operator basics, probate questions, and when to escalate.' },
  { title: 'Book a review', text: 'Move from AI intake to the MRX underwriter calendar only when the owner is ready.' },
];
---

<section class="mrx-ai-hero" aria-labelledby="mrx-ai-hero-title">
  <img
    class="mrx-ai-hero__background-image"
    src="/assets/mrx-homepage-v4/backgrounds/hero-tommy-left-layout.png"
    alt="Tommy MRX Underwriter in a West Texas oilfield at sunset"
    width="1536"
    height="1024"
    loading="eager"
    fetchpriority="high"
    aria-hidden="true"
  />
  <img
    class="mrx-ai-hero__mockup-image"
    src="/assets/mrx-homepage-v4/backgrounds/tommy-latest-mockup-20260627.jpg"
    alt=""
    width="1536"
    height="1024"
    loading="eager"
    fetchpriority="high"
    aria-hidden="true"
  />
  <div class="mrx-ai-hero__hotspots" aria-label="Homepage hero quick links">
    <a class="mrx-ai-hero__hotspot mrx-ai-hero__hotspot--home" href="/">Mineral Rights Xchange home</a>
    <a class="mrx-ai-hero__hotspot mrx-ai-hero__hotspot--worth" href="#mrx-ai-chat">What Are My Minerals Worth?</a>
    <a class="mrx-ai-hero__hotspot mrx-ai-hero__hotspot--offer-nav" href="#mrx-ai-chat">I Received An Offer</a>
    <a class="mrx-ai-hero__hotspot mrx-ai-hero__hotspot--inherited" href="#mrx-ai-chat">Inherited Mineral Rights</a>
    <a class="mrx-ai-hero__hotspot mrx-ai-hero__hotspot--learning" href="/blog">Learning Center</a>
    <a class="mrx-ai-hero__hotspot mrx-ai-hero__hotspot--about" href="/about">About MRX</a>
    <a class="mrx-ai-hero__hotspot mrx-ai-hero__hotspot--faq" href="/faq">FAQ</a>
    <a class="mrx-ai-hero__hotspot mrx-ai-hero__hotspot--book-nav" href="/book">Book Free Mineral Review</a>
    <a class="mrx-ai-hero__hotspot mrx-ai-hero__hotspot--primary" href="#mrx-ai-chat">Find Out What Your Minerals May Be Worth</a>
    <a class="mrx-ai-hero__hotspot mrx-ai-hero__hotspot--offer" href="/book">I Received An Offer</a>
    <a class="mrx-ai-hero__hotspot mrx-ai-hero__hotspot--chat-book" href="/book">Book Free Mineral Review</a>
  </div>
  <div class="mrx-ai-hero__glow mrx-ai-hero__glow--one" aria-hidden="true"></div>
  <div class="mrx-ai-hero__glow mrx-ai-hero__glow--two" aria-hidden="true"></div>

  <div class="mrx-ai-hero__shell">
    <nav class="mrx-ai-hero__nav" aria-label="AI homepage navigation">
      <a class="mrx-ai-hero__brand" href="/" aria-label="Mineral Rights Xchange home">
        <img src="/assets/brand/mrx-logo-color.png" alt="" width="400" height="100" aria-hidden="true" />
      </a>
      <div class="mrx-ai-hero__links" aria-label="Primary links">
        <a href="#mrx-ai-chat">What Are My Minerals Worth?</a>
        <a href="#mrx-ai-chat">I Received An Offer</a>
        <a href="#mrx-ai-chat">Inherited Mineral Rights</a>
        <a href="/blog">Learning Center</a>
        <a href="/about">About MRX</a>
        <a href="/faq">FAQ</a>
      </div>
      <a class="mrx-ai-hero__nav-cta" href="/book" data-cta-name="home-ai-nav-book">
        <img class="mrx-ai-icon" src="/assets/mrx-homepage-v4/icons/hmpg-v6-exact/calendar.png" alt="" aria-hidden="true" loading="eager" />
        Book Free Mineral Review
      </a>
    </nav>

    <div class="mrx-ai-hero__grid">
      <div class="mrx-ai-hero__copy">
        <p class="mrx-ai-hero__kicker">Meet Tommy™</p>
        <h1 id="mrx-ai-hero-title">Don’t Sell Your Mineral Rights Until You Know What They’re Really Worth.</h1>
        <p class="mrx-ai-hero__lede">
          Before accepting an offer, talk with Tommy. He’ll help you understand:
        </p>

        <ul class="mrx-ai-hero__checks" aria-label="What Tommy helps mineral owners understand">
          <li>What you own</li>
          <li>What your minerals may be worth</li>
          <li>Whether an offer is fair</li>
          <li>What factors impact value</li>
          <li>Whether now is the right time to sell</li>
        </ul>

        <p class="mrx-ai-hero__promise">Tommy helps you get answers before you make a decision.</p>

        <div class="mrx-ai-hero__actions" aria-label="AI calls to action">
          <a class="mrx-ai-button mrx-ai-button--primary" href="#mrx-ai-chat" data-cta-name="home-ai-primary-chat">
            <img class="mrx-ai-icon" src="/assets/mrx-homepage-v4/icons/hmpg-v6-exact/chat-bubble.png" alt="" aria-hidden="true" loading="lazy" />
            <span><strong>Find Out What Your Minerals May Be Worth</strong></span>
          </a>
          <a class="mrx-ai-button mrx-ai-button--secondary" href="/book" data-cta-name="home-ai-secondary-book">
            <img class="mrx-ai-icon" src="/assets/mrx-homepage-v4/icons/hmpg-v6-exact/document-offer.png" alt="" aria-hidden="true" loading="lazy" />
            <span><strong>I Received An Offer</strong></span>
          </a>
        </div>

      </div>

      <aside class="mrx-ai-chat" id="mrx-ai-chat" aria-label="MRX AI interaction preview">
        <div class="mrx-ai-chat__head">
          <img
            class="mrx-ai-chat__avatar"
            src="/assets/mrx-homepage-v4/avatars/tommy-mrx-underwriter-headshot.jpg"
            alt=""
            width="1254"
            height="1254"
            loading="eager"
            aria-hidden="true"
          />
          <div>
            <strong>Tommy™</strong>
            <p>MRX Underwriter</p>
            <p><span></span> Online Now</p>
          </div>
          <button type="button" class="mrx-ai-chat__more" aria-label="More MRX AI options">⋮</button>
        </div>

        <div class="mrx-ai-chat__bubble" data-ai-response>
          <strong>Hi, I’m <span>Tommy</span>.</strong><br /><br />Most mineral owners don’t need another sales pitch. They need answers.<br /><br /><b>What’s your biggest question?</b>
        </div>

        <div class="mrx-ai-chat__quick" aria-label="Start a conversation with MRX AI">
          {quickStarts.map((item) => (
            <button type="button" data-ai-prompt={item.prompt}>
              <span><img class="mrx-ai-icon" src={item.icon} alt="" aria-hidden="true" loading="lazy" /></span>
              <strong>{item.label}</strong>
              <em>→</em>
            </button>
          ))}
        </div>

        <form class="mrx-ai-chat__form" data-ai-form>
          <label class="sr-only" for="mrx-ai-answer">Ask the MRX AI Guide</label>
          <input id="mrx-ai-answer" name="answer" type="text" autocomplete="off" placeholder="Ask Tommy anything about your mineral rights..." />
          <button type="submit" aria-label="Send question to MRX AI">➤</button>
        </form>
        <div class="mrx-ai-chat__review">
          <strong>Ready for a professional review?</strong>
          <span>Talk with an MRX Underwriter about your specific property.</span>
          <a href="/book" data-cta-name="home-ai-card-book"><img class="mrx-ai-icon" src="/assets/mrx-homepage-v4/icons/hmpg-v6-exact/calendar.png" alt="" aria-hidden="true" loading="lazy" />Book Free Mineral Review →</a>
        </div>
      </aside>
    </div>

    <div class="mrx-ai-hero__benefits" aria-label="AI-first mineral rights benefits">
      {proofItems.map((item) => (
        <article>
          <span aria-hidden="true"><img class="mrx-ai-icon mrx-ai-icon--large" src={item.icon} alt="" loading="lazy" /></span>
          <div>
            <strong>{item.title}</strong>
            <p>{item.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="mrx-ai-section" aria-labelledby="mrx-ai-flow-title">
  <div class="mrx-ai-section__intro">
    <p>Focused funnel</p>
    <h2 id="mrx-ai-flow-title">Everything drives owners into the AI conversation.</h2>
    <span>The page should behave like intake, education, and routing — not a static brochure.</span>
  </div>
  <div class="mrx-ai-pathways">
    {pathways.map((item) => (
      <a href="#mrx-ai-chat" data-cta-name={`home-ai-path-${item.title.toLowerCase().replaceAll(' ', '-')}`}>
        <strong>{item.title}</strong>
        <p>{item.text}</p>
        <span>Ask the AI →</span>
      </a>
    ))}
  </div>
</section>

<section class="mrx-ai-engine" aria-labelledby="mrx-ai-engine-title">
  <div>
    <p>GHL handoff engine</p>
    <h2 id="mrx-ai-engine-title">From AI intake to calendar, CRM, and underwriter handoff.</h2>
    <p>
      The AI-first experience should collect clean context before a form or booking: situation, county/state, document status, offer status, preferred contact method, and consent. When the owner is ready, MRX routes into the existing GHL calendar and CRM fields.
    </p>
    <a class="mrx-ai-button mrx-ai-button--primary mrx-ai-engine__cta" href="/book" data-cta-name="home-ai-engine-book">Book Free Review</a>
  </div>
  <div class="mrx-ai-engine__panel" aria-label="GHL-ready owner profile preview">
    <div><span>Situation</span><strong>Offer review / inherited rights / royalty check question</strong></div>
    <div><span>Location</span><strong>State, county, operator when known</strong></div>
    <div><span>Documents</span><strong>Offer, lease, division order, royalty statement</strong></div>
    <div><span>Next step</span><strong>AI summary → GHL form/calendar → underwriter review</strong></div>
  </div>
</section>

<style>
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
  .mrx-ai-hero { position: relative; overflow: hidden; min-height: 100svh; background: #f3eee4; color: #061A33; }
  .mrx-ai-hero__background-image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: 50% top; opacity: 1; }
  .mrx-ai-hero__mockup-image { display: none; }
  .mrx-ai-hero__hotspots { display: none; }
  .mrx-ai-hero::before { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(255,255,255,.72) 0%, rgba(255,255,255,.54) 25%, rgba(255,255,255,.12) 43%, rgba(255,255,255,0) 58%, rgba(6,26,51,.16) 100%), linear-gradient(0deg, rgba(6,26,51,.22) 0%, rgba(6,26,51,0) 26%); }
  .mrx-ai-hero::after { content: ''; position: absolute; inset: auto 0 0; height: 14%; background: linear-gradient(0deg, rgba(6,26,51,.22), transparent); }
  .mrx-ai-hero__glow { position: absolute; border-radius: 999px; filter: blur(58px); opacity: .5; pointer-events: none; }
  .mrx-ai-hero__glow--one { width: 320px; height: 320px; background: rgba(216, 149, 31, .22); right: 9%; top: 20%; }
  .mrx-ai-hero__glow--two { width: 360px; height: 360px; background: rgba(42, 77, 122, .44); left: -8%; bottom: 20%; }
  .mrx-ai-hero__shell { position: relative; z-index: 1; width: min(100% - 3.5rem, 1476px); min-height: 100svh; margin: 0 auto; padding: clamp(.9rem, 1.6vw, 1.55rem) 0 0; opacity: 1; pointer-events: auto; overflow: visible; display: flex; flex-direction: column; }
  .mrx-ai-hero__nav { display: grid; grid-template-columns: 270px 1fr 265px; align-items: center; gap: clamp(1rem, 2vw, 2.2rem); min-height: 84px; padding: .72rem 1rem .72rem 1.25rem; border: 1px solid rgba(6,26,51,.08); border-radius: 20px; background: rgba(255,255,255,.97); box-shadow: 0 18px 55px rgba(6,26,51,.12); backdrop-filter: blur(18px); }
  .mrx-ai-hero__brand { display: inline-flex; align-items: center; min-width: max-content; color: #061A33; text-decoration: none; }
  .mrx-ai-hero__brand img { display: block; width: clamp(198px, 15.8vw, 250px); height: auto; object-fit: contain; }
  .mrx-ai-chat__head strong { display: block; font-size: 1rem; }
  .mrx-ai-chat__head p { display: block; margin: .1rem 0 0; color: rgba(248,251,255,.7); font-size: .82rem; }
  .mrx-ai-hero__links { display: flex; justify-content: center; align-items: center; gap: clamp(.75rem, 1.65vw, 1.85rem); font-size: clamp(.82rem, .86vw, 1rem); font-weight: 900; text-align: center; line-height: 1.35; }
  .mrx-ai-hero__links a, .mrx-ai-hero__nav-cta { color: #061A33; text-decoration: none; }
  .mrx-ai-hero__nav-cta { display: inline-flex; align-items: center; justify-content: center; gap: .55rem; min-height: 54px; border-radius: 999px; background: #061A33; padding: .85rem 1.15rem; color: #fff; box-shadow: 0 18px 44px rgba(6,26,51,.18); font-weight: 900; white-space: nowrap; }
  .mrx-ai-hero__nav-cta .mrx-ai-icon { width: 1.35rem; height: 1.35rem; }
  .mrx-ai-icon { display: block; width: 1.65rem; height: 1.65rem; object-fit: contain; }
  .mrx-ai-icon--large { width: 3rem; height: 3rem; }
  .mrx-ai-hero__grid { display: grid; grid-template-columns: minmax(0, .94fr) minmax(430px, .58fr); gap: clamp(1.25rem, 2.4vw, 3rem); align-items: center; flex: 1 1 auto; min-height: 0; padding: clamp(1.35rem, 2.2vw, 2.1rem) 0 clamp(.85rem, 1.25vw, 1.1rem); }
  .mrx-ai-hero__copy { max-width: 530px; margin-left: clamp(.25rem, 1.3vw, 1.7rem); padding: 0; border-radius: 0; background: transparent; box-shadow: none; text-shadow: 0 2px 0 rgba(255,255,255,.74), 0 12px 30px rgba(255,255,255,.64), 0 0 28px rgba(255,255,255,.48); }
  .mrx-ai-hero__kicker, .mrx-ai-section__intro p, .mrx-ai-engine > div > p:first-child { color: #f9c777; text-transform: uppercase; letter-spacing: .13em; font-weight: 900; font-size: .84rem; }
  .mrx-ai-hero__kicker { display: inline-flex; border-radius: 999px; background: #061A33; padding: .55rem 1rem; color: #fff; box-shadow: 0 10px 26px rgba(6,26,51,.18); }
  .mrx-ai-hero h1 { max-width: 540px; margin: .68rem 0 .8rem; color: #061A33; font-family: Georgia, 'Times New Roman', serif; font-size: clamp(3.6rem, 5.05vw, 5.6rem); line-height: .88; letter-spacing: -.075em; text-wrap: balance; }
  .mrx-ai-hero__lede { max-width: 470px; margin: 0; color: #061A33; font-size: clamp(1rem, 1.16vw, 1.22rem); font-weight: 900; line-height: 1.25; }
  .mrx-ai-hero__checks { display: grid; gap: .48rem; margin: .78rem 0 0; padding: 0; list-style: none; color: #061A33; font-weight: 850; }
  .mrx-ai-hero__checks li { display: flex; gap: .55rem; align-items: center; font-size: clamp(.94rem, 1.05vw, 1.08rem); }
  .mrx-ai-hero__checks li::before { content: ''; display: grid; place-items: center; flex: 0 0 auto; width: 1.22rem; height: 1.22rem; border-radius: 50%; background: url('/assets/mrx-homepage-v4/icons/hmpg-v6-exact/check-bullet.png') center / 1.22rem 1.22rem no-repeat; color: #061A33; font-size: .82rem; font-weight: 900; }
  .mrx-ai-hero__promise { display: none; }
  .mrx-ai-hero__actions { display: flex; flex-wrap: wrap; gap: .82rem; margin-top: 1.35rem; }
  .mrx-ai-button { display: inline-flex; align-items: center; justify-content: center; gap: .85rem; min-height: 70px; padding: .76rem 1.15rem; border-radius: 10px; text-decoration: none; border: 1px solid rgba(255,255,255,.22); color: #fff; }
  .mrx-ai-button strong { display: block; font-size: 1.04rem; }
  .mrx-ai-button small { display: block; color: rgba(248,251,255,.72); margin-top: .2rem; }
  .mrx-ai-button--primary { background: #D6A23A; border-color: rgba(6,26,51,.2); color: #061A33; box-shadow: 0 22px 60px rgba(196,132,28,.22); }
  .mrx-ai-button--secondary { background: #061A33; border-color: rgba(214,162,58,.78); color: #fff; }
  .mrx-ai-hero__chips { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 1.8rem; }
  .mrx-ai-hero__chips span { border: 1px solid rgba(216,225,236,.22); border-radius: 999px; padding: .75rem 1rem; color: rgba(248,251,255,.82); background: rgba(255,255,255,.035); }
  .mrx-ai-hero__trust { display: flex; gap: 1rem; align-items: center; margin-top: 2.2rem; }
  .mrx-ai-hero__trust p { margin: .1rem 0 0; color: rgba(248,251,255,.7); }
  .mrx-ai-hero__avatar-stack { display: flex; }
  .mrx-ai-hero__avatar-stack span { display: grid; place-items: center; width: 48px; height: 48px; margin-left: -10px; border-radius: 50%; border: 2px solid rgba(255,255,255,.18); background: #0a2540; color: #f9c777; font-size: .78rem; font-weight: 900; }
  .mrx-ai-hero__avatar-stack span:first-child { margin-left: 0; }
  .mrx-ai-chat { display: flex; flex-direction: column; min-height: 0; max-width: 512px; justify-self: end; border: 2px solid rgba(214,162,58,.88); border-radius: 30px; background: rgba(6,26,51,.97); box-shadow: 0 28px 100px rgba(0,0,0,.42); padding: clamp(.92rem, 1.35vw, 1.18rem); backdrop-filter: blur(18px); overflow: hidden; }
  .mrx-ai-chat__head { display: grid; grid-template-columns: 60px 1fr auto; gap: .85rem; align-items: center; }
  .mrx-ai-chat__head strong { color: #fff; font-size: 1.3rem; }
  .mrx-ai-chat__avatar { width: 60px; height: 60px; border-radius: 50%; border: 1px solid rgba(249,199,119,.5); object-fit: cover; object-position: center top; box-shadow: 0 12px 32px rgba(0,0,0,.28); }
  .mrx-ai-chat__head p span { display: inline-block; width: 9px; height: 9px; margin-right: .35rem; background: #2a8d4f; border-radius: 50%; }
  .mrx-ai-chat__more { width: 44px; height: 44px; border-radius: 50%; border: 1px solid rgba(216,225,236,.24); background: rgba(255,255,255,.05); color: #fff; font-size: 1.4rem; }
  .mrx-ai-chat__bubble { margin-top: .82rem; border-radius: 18px; background: rgba(216,225,236,.08); border: 1px solid rgba(255,255,255,.12); padding: 1rem; color: rgba(248,251,255,.94); line-height: 1.42; }
  .mrx-ai-chat__bubble span { color: #D6A23A; }
  .mrx-ai-chat__quick { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .55rem; margin-top: .82rem; padding-right: .2rem; }
  .mrx-ai-chat__quick[hidden] { display: none; }
  .mrx-ai-chat__quick button { display: grid; grid-template-columns: 30px 1fr; align-items: center; gap: .58rem; width: 100%; min-height: 58px; border: 1px solid rgba(214,162,58,.42); border-radius: 12px; background: rgba(255,255,255,.035); color: #fff; padding: .62rem .68rem; text-align: left; cursor: pointer; }
  .mrx-ai-chat__quick button strong { font-size: .86rem; line-height: 1.15; }
  .mrx-ai-chat__quick span, .mrx-ai-chat__quick em { color: #f9c777; font-style: normal; }
  .mrx-ai-chat__quick .mrx-ai-icon { width: 1.42rem; height: 1.42rem; }
  .mrx-ai-chat__form { display: grid; grid-template-columns: 1fr 46px; align-items: center; gap: .45rem; margin-top: .78rem; border: 1px solid rgba(216,225,236,.22); border-radius: 16px; padding: .42rem; }
  .mrx-ai-chat__form input { min-width: 0; background: transparent; border: 0; color: #fff; padding: .68rem; font: inherit; outline: 0; }
  .mrx-ai-chat__form button { width: 44px; height: 44px; border: 0; border-radius: 50%; background: #c4841c; color: #fff; cursor: pointer; }
  .mrx-ai-chat__review { margin-top: .78rem; text-align: center; color: rgba(248,251,255,.88); }
  .mrx-ai-chat__review strong { display: block; color: #D6A23A; }
  .mrx-ai-chat__review span { display: block; margin-top: .25rem; font-size: .9rem; }
  .mrx-ai-chat__review a { display: flex; justify-content: center; align-items: center; min-height: 50px; margin-top: .65rem; border: 1px solid #D6A23A; border-radius: 12px; color: #fff; text-decoration: none; font-weight: 900; }
  .mrx-ai-hero__benefits { display: grid; grid-template-columns: repeat(4, 1fr); margin: 0 calc(50% - 50vw); padding: .82rem max(1rem, calc((100vw - 1200px)/2)); border: 0; background: rgba(255,255,255,.96); color: #061A33; box-shadow: 0 -1px 0 rgba(6,26,51,.08); }
  .mrx-ai-hero__benefits article { display: flex; justify-content: center; align-items: center; gap: .72rem; min-height: 66px; padding: .35rem 1.1rem; border-right: 1px solid rgba(6,26,51,.14); }
  .mrx-ai-hero__benefits article:last-child { border-right: 0; }
  .mrx-ai-hero__benefits span { color: #D6A23A; font-size: 2.3rem; line-height: 1; }
  .mrx-ai-hero__benefits p { margin: .2rem 0 0; color: rgba(6,26,51,.72); line-height: 1.35; }
  .mrx-ai-section, .mrx-ai-engine { width: min(100% - 2rem, 1200px); margin: 0 auto; padding: clamp(4rem, 8vw, 7rem) 0; }
