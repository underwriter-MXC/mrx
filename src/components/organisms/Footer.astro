---
/**
 * Footer organism. The §7 disclaimer lives here, in the global
 * position that renders on every page. BaseLayout passes the
 * <Disclaimer variant="footer" /> into this organism's slot.
 */
import Disclaimer from '../molecules/Disclaimer.astro';
import { NAV, SITE } from '../../lib/site';
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__cta">
      <div>
        <p class="footer__eyebrow">Still not sure what to do?</p>
        <h2>Get a straight answer before you sign.</h2>
        <p>Tell Tommy what happened. He’ll help you take the next step one question at a time.</p>
      </div>
      <button class="footer__ask" type="button" data-footer-ask
        ><img
          src="/assets/mrx-homepage-v4/avatars/tommy-hermes-128.webp"
          alt=""
          width="128"
          height="128"
        /><span><strong>Ask Tommy</strong><small>Free, private, no pressure</small></span></button
      >
    </div>
    <div class="footer__grid">
      <div class="footer__brand-block">
        <a class="footer__logo" href="/"
          ><img
            src="/assets/brand/mrx-logo-white.png"
            alt={SITE.name}
            width="400"
            height="100"
          /></a
        >
        <p class="footer__tagline">{SITE.tagline}</p>
        <a class="footer__email" href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </div>
      <div>
        <h3 class="footer__heading">Explore MRX</h3>
        <ul class="footer__links">
          {
            NAV.footer.company.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h3 class="footer__heading">Owner resources</h3>
        <ul class="footer__links">
          {
            NAV.footer.resources.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h3 class="footer__heading">Privacy & terms</h3>
        <ul class="footer__links">
          {
            NAV.footer.legal.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <Disclaimer variant="footer" />
    <div class="footer__bottom">
      <span>© {new Date().getFullYear()} {SITE.name}. All rights reserved.</span>
      <span>Educational mineral-rights information for owners across the United States.</span>
    </div>
  </div>
</footer>

<script>
  document
    .querySelector('[data-footer-ask]')
    ?.addEventListener('click', () => window.dispatchEvent(new CustomEvent('mrx:open-chat')));
</script>
