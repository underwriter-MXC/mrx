---
/**
 * AuthorByline molecule. Author name + date + reading time on a post.
 */
interface Props {
  authorName: string;
  authorHref?: string;
  publishedAt: string;
  reviewedAt?: string;
  readingMinutes?: number;
}

const { authorName, authorHref, publishedAt, reviewedAt, readingMinutes } = Astro.props;
const formatted = new Date(publishedAt).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<p class="byline">
  <span class="byline__author">{authorHref ? <a href={authorHref}>{authorName}</a> : authorName}</span>
  <span aria-hidden="true">·</span>
  <time datetime={publishedAt}>{formatted}</time>
  {readingMinutes && (
    <>
      <span aria-hidden="true">·</span>
      <span>{readingMinutes} min read</span>
    </>
  )}
  {reviewedAt && <><span aria-hidden="true">·</span><span>Reviewed {new Date(reviewedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span></>}
</p>
