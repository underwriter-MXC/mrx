---
/**
 * Icon atom. Inline SVG sprite renderer. Pass `name` matching a file
 * in src/components/icons/*.svg, and optional size + label.
 *
 * The sprite path is /icons/<name>.svg under /public (we keep raw
 * SVGs in src/components/icons and let the build copy them as static
 * assets; alternative: inline the path strings here and serve as a
 * single sprite).
 */
interface Props {
  name: 'check' | 'arrow-right' | 'chevron-down' | 'warning' | 'shield' | 'doc' | 'scale' | 'mineral' | 'process' | 'compare' | 'book' | 'map' | 'valuation' | 'phone' | 'mail' | 'lock';
  size?: number;
  class?: string;
  ariaLabel?: string;
}

const { name, size = 24, class: className, ariaLabel } = Astro.props;
const a11y: Record<string, string | boolean> = ariaLabel
  ? { 'aria-label': ariaLabel, role: 'img' }
  : { 'aria-hidden': 'true' };
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  {...a11y}
>
  {name === 'check' && <path d="M20 6 9 17l-5-5"/>}
  {name === 'arrow-right' && <><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></>}
  {name === 'chevron-down' && <path d="m6 9 6 6 6-6"/>}
  {name === 'warning' && <><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></>}
  {name === 'shield' && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></>}
  {name === 'doc' && <><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></>}
  {name === 'scale' && <><path d="M12 3v18"/><path d="m3 9 4-6 4 6"/><path d="m13 9 4-6 4 6"/><path d="M3 9c0 4 9 4 9 0"/><path d="M12 9c0 4 9 4 9 0"/></>}
  {name === 'mineral' && <><path d="M6 3 3 6v12l3 3h12l3-3V6l-3-3z"/><path d="M9 9h6v6H9z"/></>}
  {name === 'process' && <><circle cx="6" cy="6" r="3"/><circle cx="18" cy="18" r="3"/><path d="M9 6h6a3 3 0 0 1 3 3v6"/><path d="M15 18H9a3 3 0 0 1-3-3V9"/></>}
  {name === 'compare' && <><path d="M16 3h5v5"/><path d="M3 21l18-18"/><path d="M21 16v5h-5"/><path d="M3 3l8 8"/></>}
  {name === 'book' && <><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></>}
  {name === 'map' && <><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></>}
  {name === 'valuation' && <><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></>}
  {name === 'phone' && <><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></>}
  {name === 'mail' && <><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></>}
  {name === 'lock' && <><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></>}
</svg>
