{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@lib/*": ["src/lib/*"],
      "@styles/*": ["src/styles/*"],
      "@structured-data/*": ["src/structured-data/*"]
    },
    "verbatimModuleSyntax": true,
    "allowJs": true,
    "jsx": "preserve",
    "types": ["@astrojs/cloudflare"]
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "node_modules", "public/assets/icons/react"]
}
